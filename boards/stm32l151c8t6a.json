{
  "build": {
    "core": "stm32",
    "cpu": "cortex-m3",
    "extra_flags": "-DSTM32L1xx -DSTM32L151xB -DARDUINO_GENERIC_L151C8TXA",
    "f_cpu": "32000000L",
    "mcu": "stm32l151c8t6a",
    "product_line": "STM32L151xB",
    "variant": "STM32L1xx/L100C6Ux(A)_L151C(6-8-B)(T-U)x(A)_L152C(6-8-B)(T-U)x(A)",
    "arduino": {
      "variant_h": "variant_generic.h"
    }
  },
  "debug": {
    "default_tools": ["stlink"],
    "jlink_device": "STM32L151C8",
    "onboard_tools": ["stlink"],
    "openocd_target": "stm32l1",
    "svd_path": "STM32L151xB.svd"
  },
  "frameworks": [
    "arduino",
    "cmsis",
    "stm32cube",
    "libopencm3"
  ],
  "name": "STM32L151C8T6A (32k RAM, 64k Flash)",
  "upload": {
    "maximum_ram_size": 32768,
    "maximum_size": 65536,
    "protocol": "stlink",
    "protocols": [
      "stlink",
      "jlink",
      "cmsis-dap",
      "blackmagic",
      "serial"
    ]
  },
  "url": "https://www.st.com/en/microcontrollers-microprocessors/stm32l151c8.html",
  "vendor": "ST"
}
